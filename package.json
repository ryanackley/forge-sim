{
  "name": "forge-sim",
  "version": "0.1.0",
  "description": "Simulated Forge runtime for AI-driven development and testing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ryanackley/forge-sim.git"
  },
  "homepage": "https://github.com/ryanackley/forge-sim#readme",
  "bugs": {
    "url": "https://github.com/ryanackley/forge-sim/issues"
  },
  "keywords": [
    "forge",
    "atlassian",
    "jira",
    "confluence",
    "simulator",
    "emulator",
    "testing",
    "mcp",
    "model-context-protocol",
    "uikit",
    "atlaskit"
  ],
  "engines": {
    "node": ">=22.18.0"
  },
  "files": [
    "dist",
    "renderer/src",
    "!renderer/src/__tests__",
    "renderer/package.json",
    "docs"
  ],
  "type": "module",
  "main": "./dist/simulator.js",
  "types": "./dist/simulator.d.ts",
  "exports": {
    ".": {
      "types": "./dist/simulator.d.ts",
      "import": "./dist/simulator.js"
    },
    "./shims/*": {
      "types": "./dist/shims/*.d.ts",
      "import": "./dist/shims/*.js"
    },
    "./shims/*.js": {
      "types": "./dist/shims/*.d.ts",
      "import": "./dist/shims/*.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "forge-sim": "./dist/cli.js",
    "forge-sim-mcp": "./dist/mcp-server.js",
    "forge-sim-daemon": "./dist/daemon.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js dist/mcp-server.js dist/daemon.js",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "docs": "typedoc",
    "docs:stats": "node scripts/update-stats.mjs",
    "docs:stats:check": "node scripts/update-stats.mjs --check"
  },
  "dependencies": {
    "@forge/react": "^12.0.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@vitejs/plugin-react": "^4.3.0",
    "jose": "^6.2.1",
    "mysql-memory-server": "^1.14.1",
    "mysql2": "^3.18.2",
    "mysqldump": "^3.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "ws": "^8.19.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@forge/confluence-bridge": "^3.1.0",
    "@forge/dashboards-bridge": "^0.1.17",
    "@forge/jira-bridge": "^0.40.0",
    "@forge/kvs": "^1.3.1",
    "@forge/object-store": "^2.0.0",
    "@forge/sql": "^3.0.18",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "typedoc": "^0.28.18",
    "typedoc-plugin-markdown": "^4.11.0",
    "vitest": "^3.0.0"
  }
}
